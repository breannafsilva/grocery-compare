# Live Mariano's pricing through the Kroger Product API.
# Create credentials in the Kroger developer portal and set the Mariano's store
# location id you want pricing to use.
KROGER_CLIENT_ID=
KROGER_CLIENT_SECRET=
KROGER_LOCATION_ID=
KROGER_SCOPE=product.compact

# Default UI location for finding regional providers.
NEXT_PUBLIC_DEFAULT_POSTAL_CODE=60601
