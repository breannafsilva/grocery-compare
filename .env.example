# Live Mariano's pricing through the Kroger Product API.
# Create credentials in the Kroger developer portal. Keep credentials secret.
KROGER_CLIENT_ID=
KROGER_CLIENT_SECRET=

# Non-secret defaults used for certification and deployed via Wrangler vars.
KROGER_AUTH_BASE_URL=https://api-ce.kroger.com/v1/connect/oauth2/token
KROGER_API_BASE_URL=https://api-ce.kroger.com/v1/products
KROGER_LOCATION_ID=53100508
KROGER_SCOPE=product.compact

# Default UI location for finding regional providers.
NEXT_PUBLIC_DEFAULT_POSTAL_CODE=60647
